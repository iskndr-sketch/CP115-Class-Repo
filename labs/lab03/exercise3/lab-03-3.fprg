    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="kilobyte" type="Integer" array="False" size=""/>
            <declare name="megabyte" type="Integer" array="False" size=""/>
            <declare name="gigabyte" type="Integer" array="False" size=""/>
            <declare name="terabyte" type="Integer" array="False" size=""/>
            <declare name="petabyte" type="Integer" array="False" size=""/>
            <input variable="kilobyte"/>
            <assign variable="megabyte" expression="kilobyte/1024"/>
            <assign variable="gigabyte" expression="megabyte/1024"/>
            <assign variable="terabyte" expression="gigabyte/1024"/>
            <assign variable="petabyte" expression="terabyte/1024"/>
            <output expression="megabyte" newline="True"/>
            <output expression="gigabyte" newline="True"/>
            <output expression="terabyte" newline="True"/>
            <output expression="petabyte" newline="True"/>
        </body>
    </function>
